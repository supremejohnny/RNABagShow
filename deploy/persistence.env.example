# Copy to the deployment config directory; never commit real values.
RNABAG_DEPLOY_ROOT=/home/johnny/services/rnabag
RNABAG_POSTGRES_DATA_DIR=/home/johnny/services/rnabag/postgres
RNABAG_OBJECT_DATA_DIR=/home/johnny/services/rnabag/object-storage

POSTGRES_DB=rnabag
POSTGRES_USER=rnabag
POSTGRES_PASSWORD=replace-with-a-long-random-secret
RNABAG_POSTGRES_PORT=5432
RNABAG_DATABASE_URL=postgresql://rnabag:replace-with-a-long-random-secret@127.0.0.1:5432/rnabag

MINIO_ROOT_USER=replace-with-a-random-root-access-key
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-secret
RNABAG_S3_ACCESS_KEY=replace-with-a-separate-app-access-key
RNABAG_S3_SECRET_KEY=replace-with-a-separate-app-secret
RNABAG_S3_BUCKET=rnabag-private-inputs
RNABAG_S3_ENDPOINT_URL=http://127.0.0.1:9000
RNABAG_S3_REGION=us-east-1
RNABAG_S3_PORT=9000
RNABAG_S3_CONSOLE_PORT=9001

RNABAG_PERSISTENCE_ENABLED=true
RNABAG_TEMP_DIR=/home/johnny/services/rnabag/runtime/uploads-tmp

# Restricted intranet gateway. These values are not public exposure settings.
RNABAG_GATEWAY_BIND_IP=172.16.17.4
RNABAG_GATEWAY_PORT=8080
RNABAG_GATEWAY_ALLOWED_CIDR=172.16.17.0/24
