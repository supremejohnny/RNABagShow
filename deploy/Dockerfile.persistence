FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY backend/requirements-persistence.txt /tmp/requirements-persistence.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements-persistence.txt

COPY backend /app/backend
COPY sampledata /app/sampledata

CMD ["python", "-m", "backend.app.migrate"]
